NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Use demo for static preview mode, or live for the real Supabase-backed MVP.
NEXT_PUBLIC_APP_MODE=demo
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Preferred public runtime key for the browser and SSR clients.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Backwards-compatible fallback if you still use the anon naming.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for server-side admin actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Needed for local/CI migrations and seeds, not for the Vercel runtime itself.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
RESEND_API_KEY=re_xxx
SUPPORT_EMAIL=hello@campusswap.app
# Keep APP_MODE in sync with NEXT_PUBLIC_APP_MODE.
APP_MODE=demo
DEMO_USER_PASSWORD=CampusSwap123!
DEMO_ADMIN_PASSWORD=CampusSwapAdmin123!
